# ISD Airbnb monolith environment variables
# Copy this file to .env and keep your existing credentials.

# Required by backend/monolith
MONGO_URI_USER=mongodb+srv://username:password@cluster.mongodb.net/userdb
MONGO_URI_BOOKING=mongodb+srv://username:password@cluster.mongodb.net/bookingdb
MONGO_URI_AVAILABILITY=mongodb+srv://username:password@cluster.mongodb.net/availabilitydb
MONGO_URI_NOTIFICATION=mongodb+srv://username:password@cluster.mongodb.net/notificationdb
MONGO_URI_REVIEWS=mongodb+srv://username:password@cluster.mongodb.net/reviewdb

JWT_SECRET=replace-with-a-long-secret
JWT_EXPIRY=86400000
JWT_REFRESH_EXPIRY=604800000

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=replace-with-your-supabase-service-key

FRONTEND_BASE_URL=http://localhost:3000
REACT_APP_API_BASE_URL=http://localhost:8080
REACT_APP_ENV=development

# docker-compose host port
API_GATEWAY_PORT=8080

# Legacy values from the previous microservice layout can remain in your real
# .env file if you already have them. The current monolith does not require them.
MONGO_URI_PAYMENT=
MONGO_URI_LISTING=
MONGO_URI_SEARCH=
MONGO_URI_ADMIN=
